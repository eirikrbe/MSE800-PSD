def operations(x, y, operator):
    if operator == "+":
        return x + y
    elif operator == "-":
        return x - y
    elif operator == "*":
        return x * y
    elif operator == "/":
        if y != 0:
            return x / y
        else:
            print("Error: Division by zero is not allowed.")
            return None
    elif operator == "%":
        if y != 0:
            return x % y
        else:
            print("Error: Division by zero is not allowed.")
            return None
    else:
        print("Invalid operator.")
        return None

