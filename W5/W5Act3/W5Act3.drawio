  <diagram id="C2LwIjPW1_zCk8o8Cr_h" name="Page-3">
    <mxGraphModel dx="1224" dy="816" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle Clinic System - Appointment Booking and Medication Order\n\n|Patient|\nstart\n:Log in / register;\n:Request consultation with doctor and date;\n\n|System|\n:Check appointment availability;\n\nif (Slot available?) then (Yes)\n  :Reserve appointment slot;\n\n\n  |Patient|\n  :Pay booking fee;\n\n  |System|\n  :Process booking payment;\n\n  if (Booking payment successful?) then (Yes)\n    :Confirm appointment;\n\n    |Patient|\n    :Request medication order;\n\n    |System|\n    :Validate prescription;\n\n    if (Prescription valid?) then (Yes)\n      :Calculate medication cost;\n\n      |Patient|\n      :Pay medication cost;\n\n      |System|\n      :Process medication payment;\n\n      if (Medication payment successful?) then (Yes)\n        :Send medication request to pharmacy;\n\n        |Pharmacy|\n        :Prepare medication;\n        :Dispatch medication order;\n\n        |Patient|\n        :Receive medication;\n\n      else (No)\n        |System|\n        :Cancel medication order;\n        :Notify patient of medication payment failure;\n      endif\n\n    else (No)\n      :Reject medication order;\n      :Notify patient of invalid prescription;\n    endif\n\n  else (No)\n    :Cancel reserved slot;\n    :Notify patient of booking payment failure;\n  endif\n\nelse (No)\n  :Notify patient of unavailable slot;\nendif\n\n|Patient|\n:Log out;\nstop\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="pm7I0OiGF_tg3ePpJRUq-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1355" width="2398" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
