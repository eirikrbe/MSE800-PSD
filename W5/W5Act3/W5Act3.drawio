        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n|Patient|\nstart\n:Log in / register;\n:Select doctor and time slot;\n\n|System|\nif (Slot available?) then (yes)\n\n  |Patient|\n  :Confirm appointment;\n\n  |System|\n  :Reserve slot;\n\n  |Patient|\n  :Enter payment details;\n\n  |System|\n  if (Payment successful?) then (yes)\n    :Issue booking confirmation;\n\n    |Patient|\n    :Request medication order;\n\n    |System|\n    if (Prescription valid?) then (yes)\n\n      |Pharmacy|\n      :Prepare medication;\n      :Dispatch medication order;\n\n      |Patient|\n      :Receive medication;\n\n    else (no)\n      :Reject — invalid prescription;\n    endif\n\n  else (no)\n    :Notify — payment failed;\n  endif\n\nelse (no)\n  :Notify — no available slot;\nendif\n\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="1iOi2nmYJvTvN0N0kz5R-1">
